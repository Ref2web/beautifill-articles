---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { serviceLabels, topicLabels } from '../data/site';

const articles = (await getCollection('articles')).sort(
  (a, b) => Date.parse(b.data.publishedAt) - Date.parse(a.data.publishedAt)
);
const latest = articles.slice(0, 3);
const serviceColorByCategory = Object.fromEntries(
  Object.values(serviceLabels).map((service) => [service.category, service.color])
);
const serviceCategories = [
  { id: 'nails', ...serviceLabels.nails, shortDescription: 'เลือกสี ทรง และความยาว', href: '/nails/' },
  {
    id: 'brows',
    ...serviceLabels['eyebrow-tattoo'],
    shortDescription: 'เลือกทรงให้เข้ากับหน้า',
    href: '/eyebrow-tattoo/'
  },
  {
    id: 'lips',
    ...serviceLabels['lip-tattoo'],
    shortDescription: 'เข้าใจสีและการดูแล',
    href: '/lip-tattoo/'
  }
];
---

<BaseLayout canonicalPath="/">
  <section class="home-hero">
    <div class="home-hero-copy">
      <p class="eyebrow">บทความจาก Jup</p>
      <h1>รู้ก่อนทำ สวยแบบมั่นใจขึ้น</h1>
      <p class="home-hero-text">
        รวมบทความทำเล็บ สักคิ้ว และสักปาก ที่ช่วยให้เลือกจากข้อมูลจริง
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#latest">เริ่มอ่านบทความ</a>
        <a class="button secondary" href="/about-jup">เกี่ยวกับเรา</a>
      </div>
    </div>
    <div class="home-hero-visual" aria-hidden="true">
      <picture>
        <source media="(max-width: 720px)" srcset="/images/home-hero-mobile.webp" />
        <img src="/images/home-hero-desktop.webp" alt="" />
      </picture>
    </div>
  </section>

  <section class="service-directory" aria-labelledby="service-directory-title">
    <h2 id="service-directory-title">เลือกอ่านตามบริการ</h2>
    <div class="service-grid">
      {serviceCategories.map((service) => (
        <a
          id={service.id}
          class="service-entry"
          href={service.href}
          style={`--service-color: ${service.color};`}
        >
          <span class="service-photo" aria-hidden="true">
            <img src={service.image} alt="" />
          </span>
          <span class="service-copy">
            <span class="service-title">
              <span class="service-dot"></span>
              {service.title}
            </span>
            <span>{service.shortDescription}</span>
            <span class="service-arrow" aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section id="latest" class="latest-list" aria-labelledby="latest-title">
    <div class="section-heading compact">
      <h2 id="latest-title">บทความล่าสุด</h2>
    </div>
    <div class="latest-rows">
      {latest.map((article) => (
        <article class="latest-row">
          <a href={`/blogs/news/${article.data.shopifyHandle}`}>
            <span class="row-topic">
              <span class="service-dot" style={`--service-color: ${serviceColorByCategory[article.data.category]};`}></span>
              {topicLabels[article.data.topic]?.title ?? article.data.topic}
            </span>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
            <span class="row-arrow" aria-hidden="true">›</span>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
