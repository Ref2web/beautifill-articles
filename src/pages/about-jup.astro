---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เกี่ยวกับ Jup | Beautifill by Jup"
  description="รู้จักแนวคิดของ Jup และ Beautifill: ทำเล็บ สักคิ้ว และสักปาก ควรเลือกจากข้อมูลจริง ไม่ใช่ดูแค่รูปสวย"
  canonicalPath="/about-jup"
  image="/images/about-jup-service-cover.png"
>
  <section class="about-page">
    <figure class="about-cover">
      <img
        src="/images/about-jup-service-cover.png"
        alt="ภาพรวมบริการ Beautifill by Jup ได้แก่ สักคิ้ว สักปาก สักขอบตา ต่อขนตา ทำเล็บ สักไฝ ลิฟติ้งขนตา ลิฟติ้งขนคิ้ว ลบคิ้ว และจี้ไฝ"
      />
    </figure>
    <div class="about-intro">
      <h1>ที่บิ้วตี้ฟิลล์เรามุ่งมั่นให้ความสวยเติมเต็มคุณในทุก ๆ ด้าน</h1>
      <p>
        เราดูแลตั้งแต่การให้คำแนะนำ เลือกทรง เลือกสี ไปจนถึงการดูแลหลังทำ
        เพื่อให้ลูกค้าเข้าใจสิ่งที่จะทำและเลือกสิ่งที่เหมาะกับตัวเองมากขึ้น
      </p>
    </div>
    <div class="about-card">
      <h2>ประสบการณ์และมาตรฐาน</h2>
      <ul>
        <li>เรามีประสบการณ์มากกว่า 5 ปี</li>
        <li>มีใบรับรองมาตรฐานสักคิ้วระดับ 4</li>
        <li>มีรางวัลสักคิ้วยอดเยี่ยมปี 2024</li>
        <li>มีรางวัลรองชนะเลิศอันดับ 2 การแข่งขันสักคิ้วออมเบรย์ปี 2024</li>
        <li>ผ่านการเรียนเทคนิคการสักจากอาจารย์ระดับประเทศหลายท่าน</li>
      </ul>
    </div>
    <section class="about-contact" aria-label="ช่องทางและแผนที่ Beautifill">
      <div class="contact-heading">
        <p class="eyebrow">ช่องทางและที่ตั้ง</p>
        <h2>ติดตามและดูเส้นทางมาที่ร้าน</h2>
      </div>
      <div class="contact-grid">
        <div class="embed-panel facebook-panel">
          <h3>ติดตาม Facebook</h3>
          <p>ดูผลงานล่าสุด ข่าวสาร และช่องทางติดต่อของ Beautifill</p>
          <div class="facebook-embed">
            <iframe
              title="Beautifill Facebook Page"
              src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fbeautifill.service&tabs=&width=360&height=96&small_header=true&adapt_container_width=true&hide_cover=true&show_facepile=false"
              width="360"
              height="96"
              style="border:0;overflow:hidden"
              scrolling="no"
              frameborder="0"
              allowfullscreen="true"
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
            ></iframe>
          </div>
          <a class="button secondary contact-button" href="https://www.facebook.com/beautifill.service">เปิด Facebook</a>
        </div>
        <div class="embed-panel map-panel">
          <h3>แผนที่ร้าน</h3>
          <div class="map-embed">
            <iframe
              title="Beautifill Google Map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3885.5959469939203!2d100.943084!3d13.1247639!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3102b786ac5a1701%3A0xc519affc38f13f7e!2z4Lia4Li04LmJ4Lin4LiV4Li14LmJ4Lif4Li04Lil4Lil4LmMIHwgQmVhdXRpZmlsbA!5e0!3m2!1sen!2sth!4v1781961020246!5m2!1sen!2sth"
              width="600"
              height="450"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
